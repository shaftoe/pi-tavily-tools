{
  "name": "@alexanderfortin/pi-tavily-tools",
  "author": "Alexander Fortin",
  "version": "0.5.7",
  "description": "Pi coding agent extension for web search and content extraction using Tavily",
  "keywords": [
    "pi-package",
    "tavily",
    "web-search",
    "web-extract",
    "content-extraction",
    "search"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shaftoe/pi-tavily-tools"
  },
  "scripts": {
    "build": "bun run check && tsc --project tsconfig.build.json",
    "check": "tsc --noEmit",
    "check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "bun test",
    "test:coverage": "bun test --coverage --coverage-reporter=lcov",
    "test:watch": "bun test --watch",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "0.66.0",
    "@mariozechner/pi-coding-agent": "0.66.0",
    "@mariozechner/pi-tui": "0.66.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/exec": "7.1.0",
    "@semantic-release/git": "10.0.1",
    "@semantic-release/github": "12.0.6",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.0",
    "@sinclair/typebox": "0.34.49",
    "@types/bun": "1.3.12",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "semantic-release": "25.0.3",
    "typescript": "6.0.2"
  },
  "dependencies": {
    "@tavily/core": "0.7.2",
    "temporal-polyfill": "0.3.2"
  }
}
