{
  "name": "@alexanderfortin/pi-tavily-tools",
  "author": "Alexander Fortin",
  "version": "0.1.1",
  "description": "Pi coding agent extension for web search using Tavily",
  "keywords": [
    "pi-package",
    "tavily",
    "web-search",
    "search"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "license": "MIT",
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/shaftoe/pi-tavily-tools"
  },
  "scripts": {
    "build": "bun run check && tsc",
    "check": "tsc --noEmit --project tsconfig.test.json",
    "check:watch": "tsc --noEmit --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "release": "bun run build && npm publish --access public",
    "release:dry-run": "bun run build && npm publish --dry-run"
  },
  "devDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.4.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "typescript": "^6.0.0"
  },
  "dependencies": {
    "@tavily/core": "^0.7.2"
  }
}
